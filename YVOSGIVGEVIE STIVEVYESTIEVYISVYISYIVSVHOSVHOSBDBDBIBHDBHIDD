local SniperSettings = {
    Enabled = false,
    Amount = 0
}

local oldRandom
oldRandom = hookfunction(math.random, function(...)
    local args = { ... }
    if checkcaller() then return oldRandom(...) end
    if (#args == 0) or (args[1] == -0.05 and args[2] == 0.05) or (args[1] == -0.1) or (args[1] == -0.05) then
        if SniperSettings.Enabled then
            return oldRandom(...) * (SniperSettings.Amount / 100)
        end
    end
    return oldRandom(...)
end)

