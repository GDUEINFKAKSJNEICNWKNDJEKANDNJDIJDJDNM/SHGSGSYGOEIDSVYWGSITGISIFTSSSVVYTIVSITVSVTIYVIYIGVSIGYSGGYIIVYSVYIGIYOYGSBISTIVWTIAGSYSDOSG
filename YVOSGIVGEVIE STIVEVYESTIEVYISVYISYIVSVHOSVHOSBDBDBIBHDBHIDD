local function WearItem(id)
    pcall(function()
        local head = LocalPlayer.Character:FindFirstChild("Head")
        if head then
            for _, v in pairs(head:GetChildren()) do if v:IsA("SurfaceAppearance") or v:IsA("FaceControls") or v:IsA("Decal") then v:Destroy() end end
            local face = Instance.new("Decal", head); face.Name = "face"; face.Texture = "rbxassetid://" .. id
        end
    end)
end

local function ApplyHeadless()
    if AvatarSettings.HeadlessActive and LocalPlayer.Character then
        local head = LocalPlayer.Character:FindFirstChild("Head")
        if head then head.Transparency = 1; for _, v in pairs(head:GetChildren()) do pcall(function() v.Transparency = 1 end) end end
    end
end

