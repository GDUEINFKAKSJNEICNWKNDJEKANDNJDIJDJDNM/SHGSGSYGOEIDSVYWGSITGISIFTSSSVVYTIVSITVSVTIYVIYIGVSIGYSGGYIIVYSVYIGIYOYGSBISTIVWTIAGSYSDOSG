-- [[ COMBAT LOGIC UTILS ]] --
local function isBlacklisted()
    local char = LocalPlayer.Character; local tool = char and char:FindFirstChildOfClass("Tool")
    if tool then
        local tName = tool.Name:lower()
        for _, name in pairs(TriggerSettings.Blacklist) do if string.find(tName, name:lower()) then return true end end
    end
    return false
end

local function GetClosestToCursor(radius)
    local Target, ShortestDistance = nil, radius or getgenv().FOVRadius
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and not Whitelist[v.UserId] and v.Character then
            local bestPart = nil
            for _, pName in pairs(SilentAimParts) do
                if v.Character:FindFirstChild(pName) then bestPart = v.Character[pName] break end
            end
            if bestPart then
                local hum = v.Character:FindFirstChild("Humanoid")
                local bodyEffects = v.Character:FindFirstChild("BodyEffects")
                local isKO = bodyEffects and bodyEffects:FindFirstChild("K.O") and bodyEffects["K.O"].Value
                if hum and hum.Health > 0 and (getgenv().TargetKnocked or not isKO) then
                    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(bestPart.Position)
                    if OnScreen then
                        local Dist = (UserInputService:GetMouseLocation() - Vector2.new(ScreenPos.X, ScreenPos.Y)).Magnitude
                        if Dist < ShortestDistance then ShortestDistance = Dist; Target = v end
                    end
                end
            end
        end
    end
    return Target
end

local function getFlameTarget() local t = GetClosestToCursor(math.huge); return t and t.Character and t.Character:FindFirstChild(FlameConfig.HitPart) or nil end
local function getMagnetTarget()
    local target, dist, mousePos = nil, math.huge, UserInputService:GetMouseLocation()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and not Whitelist[v.UserId] and v.Character and v.Character:FindFirstChild(MagnetSettings.TargetPart) then
            local pos, _ = Camera:WorldToViewportPoint(v.Character[MagnetSettings.TargetPart].Position)
            local d = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
            if d < dist then target = v; dist = d end
        end
    end
    return target and target.Character and target.Character:FindFirstChild(MagnetSettings.TargetPart) or nil
end

