local oldIndex = nil
oldIndex = hookmetamethod(game, "__index", function(self, Index)
    if not checkcaller() and getgenv().SilentAim and self == Mouse and (Index == "Hit" or Index == "Target") then
        local T = GetClosestToCursor()
        if T and T.Character then
            local selectedPart = T.Character:FindFirstChild("HumanoidRootPart")
            for _, pName in pairs(SilentAimParts) do
                if T.Character:FindFirstChild(pName) then selectedPart = T.Character[pName] break end
            end
            return (Index == "Hit" and selectedPart.CFrame or selectedPart) 
        end
    end
    return oldIndex(self, Index)
end)

