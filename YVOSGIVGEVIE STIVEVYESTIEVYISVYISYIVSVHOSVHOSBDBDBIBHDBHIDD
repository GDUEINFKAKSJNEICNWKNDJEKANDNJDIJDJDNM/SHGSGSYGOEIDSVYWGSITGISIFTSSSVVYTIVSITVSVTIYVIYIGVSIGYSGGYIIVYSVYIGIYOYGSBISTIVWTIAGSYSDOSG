local lastUpdate, loopFrameCount = tick(), 0
local espThrottle = 0

RunService.RenderStepped:Connect(function()
    loopFrameCount = loopFrameCount + 1
    if tick() - lastUpdate >= 1 then 
        fpsShow.Text = "Current FPS: " .. loopFrameCount; 
        if PerformanceSettings.GlobalOptimization then PerformanceSettings.RenderFrequency = (loopFrameCount < 40) and 2 or 1 end
        loopFrameCount = 0; lastUpdate = tick() 
    end
    
    if AvatarSettings.HeadlessActive then ApplyHeadless() end

    local function setSignal(s, m, a) if s then s.BackgroundColor3 = (not m and Color3.new(1,0,0) or (not a and Color3.new(1,1,0) or Color3.new(0,1,0))) end end

    local flameActive = false
    if FlameConfig.MasterLock and FlameConfig.LockActive and flameTargetPart and flameTargetPart.Parent then
        local tp = Players:GetPlayerFromCharacter(flameTargetPart.Parent)
        if tp and not Whitelist[tp.UserId] then
            local predPos = flameTargetPart.Position + (flameTargetPart.Velocity * FlameConfig.Prediction)
            local sp, on = Camera:WorldToViewportPoint(predPos + (Camera.CFrame.RightVector * FlameConfig.LeftOffset) + Vector3.new(0, FlameConfig.UpOffset, 0))
            if on then flameActive = true; local mp = UserInputService:GetMouseLocation(); mousemoverel((sp.X - mp.X) * FlameConfig.Smoothness, (sp.Y - mp.Y) * FlameConfig.Smoothness) end
        else flameTargetPart = nil end
    end
    
    local magActive = false
    if MagnetSettings.MasterEnabled and MagnetSettings.Enabled and magTarget and magTarget.Parent then
        local tp = Players:GetPlayerFromCharacter(magTarget.Parent)
        if tp and not Whitelist[tp.UserId] then
            magActive = true; local sp, _ = Camera:WorldToViewportPoint(magTarget.Position); local mp = UserInputService:GetMouseLocation(); local d = (Vector2.new(sp.X, sp.Y) - mp) * MagnetSettings.MagnetStrength; mousemoverel(d.X, d.Y)
        else MagnetSettings.Enabled = false; magTarget = nil end
    end

    if TriggerSettings.MasterEnabled and TriggerSettings.Active and not isBlacklisted() and Mouse.Target and Mouse.Target.Parent:FindFirstChild("Humanoid") then
        local tp = Players:GetPlayerFromCharacter(Mouse.Target.Parent)
        if not tp or not Whitelist[tp.UserId] then mouse1press(); task.wait(TriggerSettings.ClickDelay); mouse1release() end
    end

    if FlameConfig.MasterSpeed and FlameConfig.SpeedActive and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid.WalkSpeed = FlameConfig.WalkSpeedValue end

    setSignal(statusBars.Flame, FlameConfig.MasterLock, flameActive)
    setSignal(statusBars.Magnet, MagnetSettings.MasterEnabled, magActive)
    setSignal(statusBars.Trigger, TriggerSettings.MasterEnabled, TriggerSettings.Active)
    setSignal(statusBars.Speed, FlameConfig.MasterSpeed, FlameConfig.SpeedActive)
    setSignal(statusBars.FPS, FPSSettings.MasterEnabled, FPSSettings.MasterEnabled)
    setSignal(statusBars.Sniper, SniperSettings.Enabled, SniperSettings.Enabled)

    FOVCircle.Visible = getgenv().ShowFOV; FOVCircle.Radius = getgenv().FOVRadius; FOVCircle.Position = UserInputService:GetMouseLocation()
    
    -- Throttled ESP and rendering logic
    espThrottle = espThrottle + 1
    if espThrottle > PerformanceSettings.RenderFrequency then
        espThrottle = 0
        for plr, obj in pairs(ESPObjects) do
            local visible = false
            if ESPSettings.Enabled and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local char = plr.Character
                local hrp = char.HumanoidRootPart
                local hum = char:FindFirstChild("Humanoid")
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
                local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
                if onScreen and dist <= ESPSettings.MaxDistance then
                    visible = true
                    local trans = math.clamp(1 - (dist / ESPSettings.MaxDistance), 0.2, 1)
                    local size = Vector2.new(2500 / pos.Z, 4500 / pos.Z)
                    local top = Vector2.new(pos.X - size.X / 2, pos.Y - size.Y / 2)
                    if ESPSettings.Box then obj.Box.Size = size; obj.Box.Position = top; obj.Box.Color = ESPSettings.BoxColor; obj.Box.Transparency = trans; obj.Box.Visible = true else obj.Box.Visible = false end
                    if ESPSettings.Health and hum then
                        obj.HealthBg.Transparency = trans; obj.HealthBg.From = Vector2.new(top.X - 5, top.Y + size.Y); obj.HealthBg.To = Vector2.new(top.X - 5, top.Y); obj.HealthBg.Visible = true
                        obj.Health.Transparency = trans; obj.Health.From = Vector2.new(top.X - 5, top.Y + size.Y); obj.Health.To = Vector2.new(top.X - 5, top.Y + size.Y - (size.Y * (hum.Health/hum.MaxHealth))); obj.Health.Color = Color3.fromHSV(hum.Health/hum.MaxHealth * 0.3, 1, 1); obj.Health.Visible = true
                    else obj.Health.Visible = false; obj.HealthBg.Visible = false end
                    if ESPSettings.Skeleton then
                        for i, bone in pairs(staticBoneList) do
                            local p1, p2 = char:FindFirstChild(bone[1]), char:FindFirstChild(bone[2])
                            if p1 and p2 then
                                local b1, b2 = Camera:WorldToViewportPoint(p1.Position), Camera:WorldToViewportPoint(p2.Position)
                                obj.Bones[i].Visible = true; obj.Bones[i].From = Vector2.new(b1.X, b1.Y); obj.Bones[i].To = Vector2.new(b2.X, b2.Y); obj.Bones[i].Color = ESPSettings.SkeletonColor; obj.Bones[i].Transparency = trans
                            else obj.Bones[i].Visible = false end
                        end
                    else for _,b in pairs(obj.Bones) do b.Visible = false end end
                    if ESPSettings.Name then
                        obj.Name.Text = (Whitelist[plr.UserId] and "[WHITELISTED] " or "") .. plr.Name .. (ESPSettings.Distance and " [" .. math.floor(dist) .. "m]" or "")
                        obj.Name.Position = Vector2.new(pos.X, top.Y - 15); obj.Name.Color = ESPSettings.NameColor; obj.Name.Transparency = trans; obj.Name.Visible = true
                    else obj.Name.Visible = false end
                end
            end
            if not visible then
                obj.Box.Visible = false; obj.Name.Visible = false; obj.Health.Visible = false; obj.HealthBg.Visible = false
                for _,b in pairs(obj.Bones) do b.Visible = false end
            end
        end
    end
end)
